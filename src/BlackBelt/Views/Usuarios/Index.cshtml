@{
    ViewData["Title"] = "Usuários";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Usuarios.css" />
}

<div class="container">
    <a class="nav-link text-dark btn btn-primary" asp-area="" asp-controller="Usuarios" asp-action="Cadastro">Cadastrar Usuário</a>
    <div>
        <table class="tabelaInfo">
            <thead>
                <tr>
                    <th scope="col">Nome</th>
                    <th scope="col">CPF</th>
                    <th scope="col">Telefone</th>
                    <th scope="col">Data de Nascimento</th>
                    <th scope="col">Tipo de Usuário</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Lucas</td>
                    <td>63516581651</td>
                    <td>3140028922</td>
                    <td>15/05/2000</td>
                    <td>Administrador</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a role="button" class="btn btn-warning" asp-route-id="" asp-controller="Usuarios" asp-action="Editar">Editar</a>
                            <a role="button" class="btn btn-danger" asp-route-id="" asp-controller="Usuarios" asp-action="Excluir">Excluir</a>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
@{
}
